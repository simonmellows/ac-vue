{
  "name": "ac-vue",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "build-floorplans": "node scripts/build-floorplans.js",
    "parse-contract": "node scripts/parse-contract.js",
    "build:crestron": "vue-cli-service build && ch5-cli archive -p ac-vue -d dist -o release -c ./contract/contract.cse2j",
    "build:full": "npm run build-floorplans && npm run parse-contract && vue-cli-service build && ch5-cli archive -p ac-vue -d dist -o release -c ./public/contract/contract.cse2j"
  },
  "dependencies": {
    "@crestron/ch5-crcomlib": "^2.12.0",
    "@crestron/ch5-webxpanel": "^2.8.0",
    "@mdi/font": "^7.4.47",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "@panzoom/panzoom": "^4.5.1",
    "mitt": "^3.0.1",
    "mdi": "^2.2.43",
    "pinia": "^3.0.2",
    "vue": "^3.2.13",
    "vue-router": "^4.0.3",
    "vuetify": "^3.8.1"
  },
  "devDependencies": {
    "@vue/cli-plugin-router": "~5.0.0",
    "@vue/cli-service": "~5.0.0"
  }
}
